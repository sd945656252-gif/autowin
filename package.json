{
  "name": "jiying-platform",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "prisma generate && tsx watch apps/api/src/server.ts",
    "dev:check": "powershell -ExecutionPolicy Bypass -File scripts/dev-check.ps1",
    "dev:check:browser": "powershell -ExecutionPolicy Bypass -File scripts/dev-check.ps1 -Browser",
    "dev:check:assets": "powershell -ExecutionPolicy Bypass -File scripts/dev-check.ps1 -ProductionAssets",
    "dev:server": "tsx apps/api/src/server.ts",
    "dev:server:watch": "tsx watch apps/api/src/server.ts",
    "dev:worker": "prisma generate && tsx apps/api/src/worker.ts",
    "dev:worker:runtime": "tsx apps/api/src/worker.ts",
    "dev:worker:watch": "tsx watch apps/api/src/worker.ts",
    "build": "vite build apps/web --outDir ../../dist/web --emptyOutDir && esbuild apps/api/src/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/api/server.cjs && esbuild apps/api/src/worker.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/api/worker.cjs",
    "start": "node dist/api/server.cjs",
    "start:worker": "node dist/api/worker.cjs",
    "clean": "powershell -ExecutionPolicy Bypass -File scripts/clean-dev-artifacts.ps1",
    "clean:local-data": "powershell -ExecutionPolicy Bypass -File scripts/clean-dev-artifacts.ps1 -IncludeUserData",
    "lint": "tsc --noEmit",
    "test:unit": "node --import tsx --test \"tests/unit/*.test.ts\"",
    "security:smoke": "node scripts/security-smoke.mjs",
    "security:cleanup": "node scripts/cleanup-security-smoke-users.mjs",
    "security:repo": "node scripts/check-repo-safety.mjs",
    "security:audit": "node scripts/check-npm-audit.mjs",
    "security:smoke:production-permissions": "node scripts/production-permissions-smoke.mjs",
    "workflow:smoke:video-slash": "node scripts/video-slash-workflow-smoke.mjs",
    "workflow:smoke:editing-slash": "node scripts/editing-slash-workflow-smoke.mjs",
    "workflow:smoke:editing-archived-reference": "node scripts/editing-archived-reference-smoke.mjs",
    "workflow:smoke:production-archive": "node scripts/production-archive-lifecycle-smoke.mjs",
    "workflow:smoke:production-version": "node scripts/production-version-lifecycle-smoke.mjs",
    "workflow:smoke:production-stale-review": "node scripts/production-stale-review-smoke.mjs",
    "workflow:smoke:internal-assets-review": "node scripts/internal-assets-review-flow-smoke.mjs",
    "workflow:smoke:production-assets": "npm run workflow:smoke:video-slash && npm run workflow:smoke:editing-slash && npm run workflow:smoke:editing-archived-reference && npm run workflow:smoke:production-archive && npm run workflow:smoke:production-version && npm run workflow:smoke:production-stale-review && npm run workflow:smoke:internal-assets-review && npm run security:smoke:media-stream-access && npm run security:smoke:reference-asset-access",
    "showcase:smoke:missing-media": "node scripts/showcase-missing-media-smoke.mjs",
    "security:smoke:media-stream-access": "node scripts/media-stream-access-smoke.mjs",
    "security:smoke:reference-asset-access": "node scripts/reference-asset-access-smoke.mjs",
    "media:cleanup": "node scripts/cleanup-media-assets.mjs",
    "notification:smoke": "node scripts/notification-center-smoke.mjs",
    "pipeline:smoke:assistant": "node scripts/pipeline-assistant-smoke.mjs",
    "pipeline:smoke:assistant:persistence": "node scripts/pipeline-assistant-persistence-smoke.mjs",
    "pipeline:smoke:assistant:ui-contract": "node scripts/pipeline-assistant-ui-contract-smoke.mjs",
    "pipeline:smoke:assistant:all": "npm run pipeline:smoke:assistant && npm run pipeline:smoke:assistant:persistence && npm run pipeline:smoke:assistant:ui-contract",
    "prompt-optimization:smoke": "node scripts/prompt-optimization-smoke.mjs",
    "account:sync-primary-admins": "node scripts/sync-primary-admins.mjs",
    "account:smoke": "node scripts/account-settings-smoke.mjs",
    "account:smoke:avatar-replacement": "node scripts/avatar-replacement-smoke.mjs",
    "account:smoke:roles": "node scripts/role-access-smoke.mjs",
    "account:smoke:team-leader-scope": "node scripts/team-leader-scope-smoke.mjs",
    "account:smoke:team-project-management": "node scripts/team-project-management-smoke.mjs",
    "account:smoke:project-developer-scope": "npm run account:smoke:team-leader-scope",
    "account:smoke:all": "npm run account:smoke && npm run account:smoke:avatar-replacement && npm run account:smoke:roles && npm run account:smoke:team-leader-scope && npm run account:smoke:team-project-management",
    "api:setup": "node scripts/api-provider-wizard.mjs",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@google/genai": "^2.8.0",
    "@prisma/client": "^6.19.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.17.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "dotenv": "^17.2.3",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "fluent-ffmpeg": "^2.1.3",
    "idb-keyval": "^6.2.5",
    "ioredis": "^5.11.1",
    "lucide-react": "^0.546.0",
    "mammoth": "^1.12.0",
    "motion": "^12.23.24",
    "multer": "^2.2.0",
    "node-cron": "^4.2.1",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.19.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "textarea-caret": "^3.1.0",
    "three": "^0.184.0",
    "undici": "^8.5.0",
    "ws": "^8.21.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^5.0.4",
    "esbuild": "^0.28.1",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.4.3"
  },
  "optionalDependencies": {
    "@emnapi/core": "^1.10.0",
    "@emnapi/runtime": "^1.10.0",
    "@emnapi/wasi-threads": "^1.2.1"
  },
  "overrides": {
    "form-data": "4.0.6",
    "protobufjs": "7.6.4"
  }
}
