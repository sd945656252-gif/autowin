# Copy this file to .env for local or Podman Compose development.
#
# GEMINI_API_KEY is optional for UI preview.
# Without it, AI generation/news crawling endpoints may fail, but the app shell
# and local preview should still load.
GEMINI_API_KEY=

# Local preview URL used by server-side absolute URL generation.
APP_URL=http://localhost:3000

# Optional URL that you share with other devices, for example:
# PUBLIC_APP_URL=http://192.168.1.23:3000
PUBLIC_APP_URL=http://localhost:3000

# Comma-separated browser origins allowed to call the API when cross-origin.
# Same-origin requests do not need this. Example:
# ALLOWED_ORIGINS=http://192.168.1.23:3000,https://jiying.example.com
ALLOWED_ORIGINS=

# Request safety limits. Raise only when you intentionally handle larger payloads.
JSON_BODY_LIMIT=10mb
AUTH_RATE_LIMIT_PER_MINUTE=20
WRITE_RATE_LIMIT_PER_MINUTE=120
AI_RATE_LIMIT_PER_MINUTE=20
UPLOAD_MAX_MB=25
# Featured/showcase videos accept up to 1GB. The backend also caps this value at 1024.
SHOWCASE_UPLOAD_MAX_MB=1024
# Keep showcase transcoding disabled by default. Stable uploads must not depend on ffmpeg.
# Production images include ffmpeg, but set this to true only after verifying:
#   podman compose exec -T jiying-web ffmpeg -version
#   podman compose exec -T jiying-web ffprobe -version
# If enabled and ffmpeg/ffprobe are unavailable or fail, uploads fall back to the original file
# and record the transcode failure in ShowcaseWork/MediaAsset metadata.
SHOWCASE_TRANSCODE_ENABLED=false
DEVELOPER_MEDIA_MAX_MB=200
USER_UPLOAD_QUOTA_MB=500

# Realtime collaboration safety limits.
WS_MAX_MESSAGE_BYTES=65536
WS_RATE_LIMIT_PER_MINUTE=120
WS_MAX_VIOLATIONS=3

# Google OAuth. Required only if you want one-click Google login.
# In Google Cloud Console, add this authorized redirect URI:
#   ${PUBLIC_APP_URL}/api/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Redis-backed workflow queue for Podman Compose local sharing.
REDIS_URL=redis://localhost:16379

# Web/API process should not run the workflow worker when Podman Compose starts
# the dedicated jiying-worker service.
WORKFLOW_WORKER_ENABLED=false
WORKFLOW_WORKER_CONCURRENCY=2

# Uploaded images, videos, and generated media are stored locally under this
# directory. Podman Compose persists it with the jiying_uploads named volume.
UPLOADS_DIR=uploads

# Protected developer-only media lives outside frontend public assets.
PRIVATE_STORAGE_DIR=storage/private

# Local PostgreSQL connection used by Prisma. In Podman Compose the app uses
# the same credentials with host `postgres`.
DATABASE_URL=postgresql://jiying:jiying_dev_password@localhost:15432/jiying?schema=public

# 32-byte key used to encrypt Custom API keys at rest.
# Replace this in any shared/staging/production environment.
ENCRYPTION_KEY=replace_with_32_byte_secret_key

# Local-only provider config imported on backend startup. Copy
# config/api-providers.example.json to this path and fill real keys there.
API_PROVIDER_CONFIG_PATH=config/api-providers.local.json

# Set true before any broader sharing/staging run to fail fast when default
# development secrets are still present.
REQUIRE_STRONG_LOCAL_SECRETS=false
LOCAL_TEAM_MODE=false
CSP_STRICT_STYLE=false
CSP_STYLE_SRC_EXTRA=
REQUIRE_AUTH_FOR_TEAM_MODE=true

# Outbound provider URL safety. Keep false by default to block SSRF to localhost,
# private IP ranges, and link-local addresses. For a local model gateway, prefer
# listing a specific hostname in OUTBOUND_PRIVATE_HOST_ALLOWLIST.
ALLOW_PRIVATE_PROVIDER_URLS=false
OUTBOUND_PRIVATE_HOST_ALLOWLIST=

# Inline API keys in workflow execution requests are disabled by default. Store
# provider keys via npm run api:setup or the backend API config store instead.
ALLOW_INLINE_CUSTOM_API_KEYS=false

# Optional AI news search providers. These keys are read only by the backend;
# they are never returned to the browser. Without them, news refresh still uses
# the fixed trusted source list.
TAVILY_API_KEY=
BRAVE_SEARCH_API_KEY=

# Optional extra AI news RSS/Atom sources. Use either a comma-separated URL list
# or a JSON array. Added sources still pass backend outbound URL safety checks.
# Example:
# NEWS_BROADCAST_EXTRA_RSS_SOURCES=[{"name":"Example AI RSS","url":"https://example.com/rss.xml","category":"外部 RSS 新闻","trustLevel":"MEDIA","maxItemsPerFetch":12}]
NEWS_BROADCAST_EXTRA_RSS_SOURCES=

# Keep local development startup fast when external news/model sources are slow
# or unavailable. Manual refresh endpoints still work.
DISABLE_STARTUP_NEWS_REFRESH=true

# Optional outbound proxy for Podman containers. On Windows, local proxy apps
# often listen only on 127.0.0.1. scripts/start-podman-dev.ps1 can expose that
# local proxy on port 7898 and point containers at a Podman-reachable host IP.
# Example:
# CONTAINER_HTTPS_PROXY=http://172.19.1.27:7898
# CONTAINER_HTTP_PROXY=http://172.19.1.27:7898
CONTAINER_HTTPS_PROXY=
CONTAINER_HTTP_PROXY=
CONTAINER_ALL_PROXY=
CONTAINER_NO_PROXY=localhost,127.0.0.1,::1,postgres,redis

# Comma-separated exact admin emails. Do not use wildcard or prefix matching.
PRIMARY_ADMIN_EMAILS=

# Initial local ADMIN seed. Change the password before sharing on LAN.
SEED_ADMIN_EMAIL=admin@jiying.local
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=JiyingAdmin123!
SEED_ADMIN_DISPLAY_NAME=Jiying Admin
