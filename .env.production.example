# Copy this file to .env.production or use these variables in your host/container platform.
# Do not reuse local development secrets for shared or public deployments.

NODE_ENV=production
APP_URL=https://jiying.example.com
PUBLIC_APP_URL=https://jiying.example.com
ALLOWED_ORIGINS=https://jiying.example.com

# Generate a long random password for the production database user.
POSTGRES_PASSWORD=replace_with_strong_postgres_password

# At least 32 bytes. Example generation:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
ENCRYPTION_KEY=replace_with_at_least_32_byte_secret

DATABASE_URL=postgresql://jiying:replace_with_strong_postgres_password@postgres:5432/jiying?schema=public
REDIS_URL=redis://redis:6379

JSON_BODY_LIMIT=10mb
AUTH_RATE_LIMIT_PER_MINUTE=20
WRITE_RATE_LIMIT_PER_MINUTE=120
UPLOAD_MAX_MB=100

UPLOADS_DIR=/app/uploads
PRIVATE_STORAGE_DIR=/app/storage/private
API_PROVIDER_CONFIG_PATH=config/api-providers.local.json
REQUIRE_STRONG_LOCAL_SECRETS=true

# Optional. Required only for Google OAuth login.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Optional. Required only for Gemini-backed AI/news functions.
GEMINI_API_KEY=

WORKFLOW_WORKER_ENABLED=false
WORKFLOW_WORKER_CONCURRENCY=2
